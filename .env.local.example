# -------------- Supabase Config --------------
# Project URL: https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Anon Key: Client-side access (Respects RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service Role Key: Server-side access (Bypasses RLS)
# WARNING: NEVER expose this value on the client-side!
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -------------- Database Connections --------------
# Note: Use Direct connection for Supabase VPC, Transaction for Pooling
DIRECT_URL=postgresql://postgres:[password]@[host]:5432/postgres
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres?pgbouncer=true

# -------------- Analytics (Placeholder) --------------
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# BIGQUERY_DATASET_ID=green_deli_events
